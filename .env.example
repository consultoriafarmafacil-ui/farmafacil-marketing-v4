# .env.example — Farma Fácil Sistema V4
# Copie este arquivo para .env e preencha com seus dados
# NUNCA commite o arquivo .env no GitHub!

# Token de acesso à API do Meta (Facebook/Instagram)
# Obtenha em: Meta Business Suite → Configurações → API
META_ACCESS_TOKEN=seu_token_aqui

# IDs da conta (já preenchidos)
ASSET_ID=109761077453312
BUSINESS_ID=137336747461436

# GitHub Personal Access Token (Fine-grained)
# Necessário para publicação automática via HTML
# Crie em: GitHub → Settings → Developer settings → Personal access tokens → Fine-grained token
# Permissão necessária: Contents: write (no repositório farmafacil-marketing-v4)
GITHUB_TOKEN=seu_github_token_aqui
